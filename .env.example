# Anthropic API key — console.anthropic.com -> Get API Keys
ANTHROPIC_API_KEY=

# Strava API app — strava.com/settings/api (Authorization Callback Domain: localhost)
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# Local SQLite database
DATABASE_URL=sqlite:///./arete.db

# Where the Strava MCP server writes exported route files (GPX/TCX)
STRAVA_ROUTE_EXPORT_PATH=./data/routes
